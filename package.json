        "@sveltejs/kit": "^2.68.0",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tailwindcss/typography": "^0.5.20",
        "@tailwindcss/vite": "^4.3.1",
        "@types/node": "^26.0.1",
        "@types/three": "^0.184.1",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.19.0",
        "globals": "^17.7.0",
        "mdsvex": "^0.12.7",
        "prettier": "^3.8.4",
